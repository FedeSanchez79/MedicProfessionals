PORT=3001
JWT_SECRET=cambia_esto_por_una_clave_secreta

# Ruta a la base de datos compartida con MedicData.
# Por defecto apunta a ../medicdata/database/medicdata.db
# (ambas carpetas deben estar en el mismo directorio, ej. Desktop)
# DB_PATH=../medicdata/database/medicdata.db

# Email — Gmail con App Password (activá 2FA y generá un App Password en myaccount.google.com/apppasswords)
MAIL_USER=tu_email@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx

# URL pública del servidor (usada en el link de reseteo que se envía por email)
APP_URL=https://localhost:3001

# URL del servicio MedicData (donde viven los tokens QR y los datos de pacientes)
# Producción: https://medicdata-production.up.railway.app
MEDICDATA_URL=https://medicdata-production.up.railway.app
